import { BrowserRouter, Navigate, Route, Routes } from "react-router-dom";
import { LoginForm } from "@/components/login-form";


import "./App.css";

function App() {
  return (
    <BrowserRouter>
      <Routes>
        <Route path="/login" element={<LoginForm />} />

        <Route path="/" element={<Navigate to="/login" replace />} />
      </Routes>
    </BrowserRouter>
  );
}

export default App;
